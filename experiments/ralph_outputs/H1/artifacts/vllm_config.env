# vllm_config.env — single source of truth for the local vLLM eval endpoint.
# Sourced by serve_vllm.sh (server side) and read by vllm_client.py (client side,
# via VLLM_BASE_URL / VLLM_MODEL / VLLM_API_KEY). Keep server + client in sync here.

# --- model ---
# Small instruct model: low VRAM (~4GB fp16 for 1.5B), fast, good enough as an eval
# policy. Swap to Qwen2.5-3B/7B-Instruct or meta-llama/Llama-3.2-3B-Instruct for more.
MODEL=Qwen/Qwen2.5-1.5B-Instruct
SERVED_NAME=vllm-local

# --- server bind ---
HOST=127.0.0.1
PORT=8000
MAX_LEN=8192
GPU_UTIL=0.90
DTYPE=auto
VLLM_API_KEY=local-key

# --- client (consumed by vllm_client.py / the OpenAI-compatible shim) ---
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_MODEL=vllm-local
